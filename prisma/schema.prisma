generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AppRole {
  ADMINISTRATOR
  VIEWER
  TRAINER
  TRAINEE
  GUEST_TRAINER
  CONTRACTUAL_EMPLOYEE
}

enum TrainingType {
  MATERIAL_MCQ          // material + assessment — completes only after passing
  MATERIAL_ONLY         // completes when the material has been opened/read
  ACKNOWLEDGEMENT_ONLY  // completes when the trainee clicks acknowledge
}

enum TrainingTrigger {
  INDUCTION
  UPGRADE
  RETRAINING
  REFRESHER
  TECHNICAL
  EXTERNAL
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  FAILED
}

enum ContentStatus {
  DRAFT
  APPROVED
  RETIRED
}

enum VersionType {
  MAJOR
  MINOR
}

enum FileType {
  PPT
  PDF
  VIDEO
  OTHER
}

enum AssessmentType {
  MCQ
  ORAL
}

enum AssessmentOutcome {
  PASS
  FAIL
  NEEDS_RETRAINING
}

enum QualStatus {
  INITIATED
  IN_PROGRESS
  APPROVED
  EXPIRED
  REVOKED
}

enum QualOutcome {
  COMPETENT
  NOT_YET_COMPETENT
}

enum TechniqueType {
  METHOD
  INSTRUMENT
  TECHNIQUE
}

enum SignatoryRole {
  TRAINER
  QA
  QA_MANAGER
  TRAINING_HEAD
}

enum SignatoryStatus {
  PENDING
  SIGNED
  REJECTED
}

enum NotificationType {
  ASSIGNMENT
  DUE_SOON
  OVERDUE
  FAILED
  RETRAINING
  QUALIFICATION_EXPIRY
  PASSWORD_RESET
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  UPLOAD
  GENERATE
  ASSIGN
  REVOKE
}

enum RefresherTriggerType {
  PLANNED
  DEVIATION
  INCIDENT
}

enum RefresherStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum TestPhase {
  IQ
  OQ
  PQ
  RT
}

enum TestStatus {
  NOT_EXECUTED
  PASS
  FAIL
  BLOCKED
}

enum ValidationStatus {
  PLANNED
  IN_PROGRESS
  COMPLETE
  LOCKED
}

// ─────────────────────────────────────────────
// FOUNDATION MODELS
// ─────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  units       Unit[]
  persons     Person[]
  techniques  Technique[]
  topicScopes TopicScope[]

  @@map("departments")
}

model Unit {
  id           String   @id @default(cuid())
  name         String
  code         String
  departmentId String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  department  Department   @relation(fields: [departmentId], references: [id])
  sections    Section[]
  persons     Person[]
  topicScopes TopicScope[]

  @@unique([departmentId, code])
  @@map("units")
}

model Section {
  id        String   @id @default(cuid())
  name      String
  code      String
  unitId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  unit        Unit         @relation(fields: [unitId], references: [id])
  persons     Person[]
  topicScopes TopicScope[]

  @@unique([unitId, code])
  @@map("sections")
}

model PersonRole {
  id       String  @id @default(cuid())
  personId String
  role     AppRole

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, role])
  @@map("person_roles")
}

model Person {
  id                     String    @id @default(cuid())
  employeeId             String    @unique
  name                   String
  email                  String?   @unique
  passwordHash           String
  mustChangePassword     Boolean   @default(true)
  designation            String
  isActive               Boolean   @default(true)
  joiningDate            DateTime
  lastLoginAt            DateTime?
  departmentId           String
  unitId                 String
  sectionId              String?   // optional — not all units have sections
  managerId              String?
  flaggedForJobReassignment Boolean  @default(false)
  flaggedAt              DateTime?
  flagReason             String?
  flagTopicId            String?
  flagCycleCount         Int?
  resolvedAt             DateTime?
  resolvedById           String?
  resolutionAction       String?
  resolutionNotes        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  roles                    PersonRole[]
  department               Department            @relation(fields: [departmentId], references: [id])
  unit                     Unit                  @relation(fields: [unitId], references: [id])
  section                  Section?              @relation(fields: [sectionId], references: [id])
  manager                  Person?               @relation("manages", fields: [managerId], references: [id])
  subordinates             Person[]              @relation("manages")
  trainingAssignments      TrainingAssignment[]
  assessmentAttempts       AssessmentAttempt[]
  qualificationRecords     QualificationRecord[] @relation("qualifiedPerson")
  supervisedQualifications QualificationRecord[] @relation("supervisor")
  initiatedQualifications  QualificationRecord[] @relation("initiator")
  signatoryEntries         SignatoryEntry[]
  uploadedDocuments        ScannedDocument[]
  issuedCertificates       Certificate[]         @relation("issuer")
  personCertificates       Certificate[]         @relation("certPerson")
  notifications            Notification[]
  auditLogs                AuditLog[]
  refresherRaisedBy        RefresherTrigger[]    @relation("raisedBy")
  refresherPersons         RefresherTrigger[]    @relation("refresherPerson")
  uploadedContent          MaterialVersion[]     @relation("contentUploader")
  approvedContent          MaterialVersion[]     @relation("contentApprover")
  createdTopics            TrainingTopic[]
  createdAssignments       TrainingAssignment[]  @relation("assignedBy")
  trainerCertificates      TrainerCertificate[]  @relation("trainerCertPerson")
  issuedTrainerCertificates  TrainerCertificate[] @relation("trainerCertIssuer")
  revokedTrainerCertificates TrainerCertificate[] @relation("trainerCertRevoker")
  validationRunsExecuted   ValidationRun[]       @relation("valRunExecutor")
  validationRunsApproved   ValidationRun[]       @relation("valRunApprover")
  testResultsExecuted      TestResult[]          @relation("testResultExecutor")

  @@map("persons")
}

// ─────────────────────────────────────────────
// TRAINING TOPIC + CONTENT
// ─────────────────────────────────────────────

model TrainingTopic {
  id           String       @id @default(cuid())
  name         String
  description  String?
  trainingType TrainingType @default(MATERIAL_MCQ)
  isActive     Boolean      @default(true)
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  createdBy   Person               @relation(fields: [createdById], references: [id])
  topicScopes TopicScope[]
  materials   TrainingMaterial[]
  questionBank QuestionBank?
  assignments TrainingAssignment[]
  refreshers  RefresherTrigger[]

  @@map("training_topics")
}

// Topic → Department/Unit/Section scope (compulsory-training targeting +
// induction auto-assign). unitId/sectionId narrow the scope when set;
// department-only (unitId/sectionId both null) means "whole department".
model TopicScope {
  id           String   @id @default(cuid())
  topicId      String
  departmentId String
  unitId       String?
  sectionId    String?
  createdAt    DateTime @default(now())

  topic      TrainingTopic @relation(fields: [topicId], references: [id])
  department Department    @relation(fields: [departmentId], references: [id])
  unit       Unit?         @relation(fields: [unitId], references: [id])
  section    Section?      @relation(fields: [sectionId], references: [id])

  @@map("topic_scopes")
}

model TrainingMaterial {
  id             String        @id @default(cuid())
  title          String
  topicId        String
  currentVersion Int           @default(1)
  status         ContentStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  topic    TrainingTopic     @relation(fields: [topicId], references: [id])
  versions MaterialVersion[]

  @@map("training_materials")
}

model TrainerCertificate {
  id            String    @id @default(cuid())
  personId      String
  issuedById    String
  certNumber    String    @unique
  basis         String
  isActive      Boolean   @default(true)
  issuedAt      DateTime  @default(now())
  revokedAt     DateTime?
  revokedById   String?
  revokedReason String?

  person    Person  @relation("trainerCertPerson",  fields: [personId],   references: [id])
  issuedBy  Person  @relation("trainerCertIssuer",  fields: [issuedById], references: [id])
  revokedBy Person? @relation("trainerCertRevoker", fields: [revokedById], references: [id])

  @@map("trainer_certificates")
}

model MaterialVersion {
  id            String        @id @default(cuid())
  materialId    String
  versionNo     Int
  versionLabel  String
  versionType   VersionType
  fileUrl       String
  fileName      String
  fileType      FileType
  changeSummary String
  effectiveDate DateTime
  status        ContentStatus @default(DRAFT)
  uploadedById  String
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime      @default(now())

  material   TrainingMaterial @relation(fields: [materialId],  references: [id])
  uploadedBy Person           @relation("contentUploader", fields: [uploadedById], references: [id])
  approvedBy Person?          @relation("contentApprover", fields: [approvedById], references: [id])

  @@unique([materialId, versionNo])
  @@map("material_versions")
}

// ─────────────────────────────────────────────
// TRAINING ASSIGNMENT
// ─────────────────────────────────────────────

model TrainingAssignment {
  id                 String           @id @default(cuid())
  personId           String
  topicId            String
  trigger            TrainingTrigger
  status             AssignmentStatus @default(NOT_STARTED)
  assignedById       String
  dueDate            DateTime
  startedAt          DateTime?
  viewedAt           DateTime?
  completedAt        DateTime?
  acknowledged       Boolean          @default(false)
  needIdentifiedById String?
  needBasis          String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  person     Person              @relation(fields: [personId],     references: [id])
  topic      TrainingTopic       @relation(fields: [topicId],      references: [id])
  assignedBy Person              @relation("assignedBy", fields: [assignedById], references: [id])
  attempts   AssessmentAttempt[]

  @@map("training_assignments")
}

// ─────────────────────────────────────────────
// ASSESSMENT
// ─────────────────────────────────────────────

model QuestionBank {
  id                  String         @id @default(cuid())
  topicId             String         @unique
  passingPercentage   Float          @default(80)
  questionsPerAttempt Int            @default(10)
  maxAttempts         Int            @default(3)
  isActive            Boolean        @default(true)
  assessmentType      AssessmentType @default(MCQ)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  topic     TrainingTopic       @relation(fields: [topicId], references: [id])
  questions Question[]
  attempts  AssessmentAttempt[]

  @@map("question_banks")
}

model Question {
  id            String   @id @default(cuid())
  bankId        String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bank QuestionBank @relation(fields: [bankId], references: [id])

  @@map("questions")
}

model AssessmentAttempt {
  id           String            @id @default(cuid())
  personId     String
  bankId       String
  assignmentId String
  attemptNo    Int
  score        Float
  outcome      AssessmentOutcome
  answers      Json
  startedAt    DateTime
  submittedAt  DateTime
  createdAt    DateTime          @default(now())

  person     Person             @relation(fields: [personId],     references: [id])
  bank       QuestionBank       @relation(fields: [bankId],       references: [id])
  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id])

  @@map("assessment_attempts")
}

// ─────────────────────────────────────────────
// REFRESHER TRAINING
// ─────────────────────────────────────────────

model RefresherTrigger {
  id            String               @id @default(cuid())
  personId      String
  topicId       String
  triggerType   RefresherTriggerType
  status        RefresherStatus      @default(PENDING)
  justification String
  raisedById    String
  dueDate       DateTime
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  person   Person        @relation("refresherPerson", fields: [personId],  references: [id])
  topic    TrainingTopic @relation(fields: [topicId],                       references: [id])
  raisedBy Person        @relation("raisedBy",        fields: [raisedById], references: [id])

  @@map("refresher_triggers")
}

// ─────────────────────────────────────────────
// SCIENTIST QUALIFICATION
// ─────────────────────────────────────────────

model Technique {
  id                      String        @id @default(cuid())
  name                    String
  code                    String        @unique
  type                    TechniqueType
  departmentId            String
  qualificationPeriodDays Int           @default(365)
  isActive                Boolean       @default(true)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  department     Department            @relation(fields: [departmentId], references: [id])
  qualifications QualificationRecord[]

  @@map("techniques")
}

model QualificationRecord {
  id                String      @id @default(cuid())
  personId          String
  techniqueId       String
  status            QualStatus  @default(INITIATED)
  outcome           QualOutcome?
  performedOn       DateTime?
  supervisorId      String?
  initiatedById     String
  initiatedAt       DateTime    @default(now())
  approvedAt        DateTime?
  expiryDate        DateTime?
  requalificationOf String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  person          Person               @relation("qualifiedPerson", fields: [personId],      references: [id])
  technique       Technique            @relation(fields: [techniqueId],                        references: [id])
  supervisor      Person?              @relation("supervisor",       fields: [supervisorId],   references: [id])
  initiatedBy     Person               @relation("initiator",        fields: [initiatedById],  references: [id])
  previousQual    QualificationRecord?  @relation("requalification",  fields: [requalificationOf], references: [id])
  nextQuals       QualificationRecord[] @relation("requalification")
  signatories     SignatoryEntry[]
  scannedDocuments ScannedDocument[]
  certificate     Certificate?

  @@map("qualification_records")
}

model SignatoryEntry {
  id              String          @id @default(cuid())
  qualificationId String
  stepOrder       Int
  requiredRole    SignatoryRole
  signedById      String?
  signedAt        DateTime?
  justification   String?
  status          SignatoryStatus @default(PENDING)
  createdAt       DateTime        @default(now())

  qualification QualificationRecord @relation(fields: [qualificationId], references: [id])
  signedBy      Person?             @relation(fields: [signedById],       references: [id])

  @@unique([qualificationId, stepOrder])
  @@map("signatory_entries")
}

model ScannedDocument {
  id              String   @id @default(cuid())
  qualificationId String
  fileUrl         String
  fileName        String
  fileType        String
  description     String
  uploadedById    String
  uploadedAt      DateTime @default(now())

  qualification QualificationRecord @relation(fields: [qualificationId], references: [id])
  uploadedBy    Person              @relation(fields: [uploadedById],    references: [id])

  @@map("scanned_documents")
}

model Certificate {
  id              String   @id @default(cuid())
  certNumber      String   @unique
  qualificationId String   @unique
  personId        String
  issuedById      String
  issuedAt        DateTime @default(now())
  fileUrl         String
  validUntil      DateTime

  qualification QualificationRecord @relation(fields: [qualificationId], references: [id])
  person        Person              @relation("certPerson", fields: [personId],   references: [id])
  issuedBy      Person              @relation("issuer",     fields: [issuedById], references: [id])

  @@map("certificates")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id       String              @id @default(cuid())
  personId String
  type     NotificationType
  channel  NotificationChannel
  title    String
  message  String
  isRead   Boolean             @default(false)
  sentAt   DateTime            @default(now())
  readAt   DateTime?

  person Person @relation(fields: [personId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// AUDIT TRAIL
// ─────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  userId        String
  action        AuditAction
  module        String
  recordId      String
  recordType    String
  beforeValue   Json?
  afterValue    Json?
  justification String
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  user Person @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// VALIDATION SUPPORT
// ─────────────────────────────────────────────

model ValidationRun {
  id           String           @id @default(cuid())
  phase        TestPhase
  version      String
  environment  String
  status       ValidationStatus @default(PLANNED)
  startedAt    DateTime?
  completedAt  DateTime?
  executedById String?
  approvedById String?
  approvedAt   DateTime?
  notes        String?
  createdAt    DateTime         @default(now())

  executedBy  Person?      @relation("valRunExecutor", fields: [executedById], references: [id])
  approvedBy  Person?      @relation("valRunApprover", fields: [approvedById], references: [id])
  testResults TestResult[]

  @@map("validation_runs")
}

model TestCase {
  id          String    @id @default(cuid())
  ursId       String
  module      String
  phase       TestPhase
  title       String
  description String
  steps       String
  expected    String
  priority    String    @default("M")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  results TestResult[]

  @@map("test_cases")
}

model TestResult {
  id             String     @id @default(cuid())
  runId          String
  testCaseId     String
  status         TestStatus @default(NOT_EXECUTED)
  actualResult   String?
  defectNotes    String?
  executedById   String?
  executedAt     DateTime?
  screenshotUrls String[]
  createdAt      DateTime   @default(now())

  run        ValidationRun @relation(fields: [runId],       references: [id])
  testCase   TestCase      @relation(fields: [testCaseId],  references: [id])
  executedBy Person?       @relation("testResultExecutor", fields: [executedById], references: [id])

  @@unique([runId, testCaseId])
  @@map("test_results")
}
