# ─────────────────────────────────────────────────────────────────
# .dockerignore — files Docker should never copy into containers
# Similar to .gitignore but for Docker builds
# ─────────────────────────────────────────────────────────────────

# Node modules — too large, rebuilt inside container
node_modules/

# Next.js build output
.next/

# Environment files — never bake secrets into images
.env
.env.local
.env.*.local

# Storage data — not part of the code
storage/

# Version control
.git/
.gitignore

# Development files
*.log
*.md
.DS_Store
Thumbs.db

# Test files
coverage/
__tests__/
*.test.ts
*.spec.ts

# TypeScript cache
*.tsbuildinfo